rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    function isAdmin() {
      return userDoc().role == 'admin';
    }
    function belongsToWorkspace(workspaceId) {
      return userDoc().workspace_id == workspaceId;
    }

    // Perfil de usuário: leitura pelo próprio ou por membro do mesmo workspace
    match /users/{userId} {
      allow read: if request.auth != null && (
        request.auth.uid == userId ||
        resource.data.workspace_id == userDoc().workspace_id
      );
      allow create: if request.auth != null;
      allow update: if request.auth != null && (
        request.auth.uid == userId || isAdmin()
      );
    }

    // Workspace: apenas membros acessam o documento raiz
    match /workspaces/{workspaceId} {
      allow read, write: if request.auth != null && belongsToWorkspace(workspaceId);

      // Tickets: apenas membros do workspace
      match /tickets/{ticketId} {
        allow read: if request.auth != null && belongsToWorkspace(workspaceId);
        allow create: if request.auth != null
          && belongsToWorkspace(workspaceId)
          && request.resource.data.creator_id == request.auth.uid;
        allow update, delete: if request.auth != null
          && belongsToWorkspace(workspaceId)
          && (resource.data.creator_id == request.auth.uid || isAdmin());

        // Comentários: apenas membros do workspace
        match /comments/{commentId} {
          allow read: if request.auth != null && belongsToWorkspace(workspaceId);
          allow create: if request.auth != null
            && belongsToWorkspace(workspaceId)
            && request.resource.data.author_id == request.auth.uid;
          allow delete: if request.auth != null
            && belongsToWorkspace(workspaceId)
            && (resource.data.author_id == request.auth.uid || isAdmin());
        }
      }
    }
  }
}
